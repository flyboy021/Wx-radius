{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/controls/**",
              "components/feedback/**",
              "components/weather/**",
              "ui_kits/vicinity-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:accent|ghost|cta|danger)$/]",
        "message": "<Button> variant must be one of 'accent' | 'ghost' | 'cta' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|variant|style|key|ref|className|style|children)$/]",
        "message": "<CategoryPill> doesn't accept that prop. Declared props: category, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryPill'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pill|dot|text)$/]",
        "message": "<CategoryPill> variant must be one of 'pill' | 'dot' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|role|onRemove|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: label, role, onRemove, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:dep|dest|via)$/]",
        "message": "<Chip> role must be one of 'dep' | 'dest' | 'via'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Legend'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<Legend> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|confirmLabel|onConfirm|tone|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, title, children, confirmLabel, onConfirm, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:danger|accent)$/]",
        "message": "<Modal> tone must be one of 'danger' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ribbon'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|category|label|message|warn|style|key|ref|className|style|children)$/]",
        "message": "<Ribbon> doesn't accept that prop. Declared props: status, category, label, message, warn, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ribbon'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:ok|advisory)$/]",
        "message": "<Ribbon> status must be one of 'ok' | 'advisory'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StationCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icao|name|distance|category|raw|onClick|style|key|ref|className|style|children)$/]",
        "message": "<StationCard> doesn't accept that prop. Declared props: icao, name, distance, category, raw, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:metar|taf|atis|neutral)$/]",
        "message": "<Tag> tone must be one of 'metar' | 'taf' | 'atis' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:uppercase|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: uppercase."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:on|accent|children|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: on, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:blue|amber)$/]",
        "message": "<Toggle> accent must be one of 'blue' | 'amber'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
